#compdef Rscript
# Zsh completion for the rlang `Rscript` binary.

_Rscript() {
  local -a opts
  opts=(
    '-e[execute a one-liner]:source'
    '--eval[execute a one-liner]:source'
    '--repl[start the interactive REPL]'
    '--lsp[speak the Language Server Protocol over stdio]'
    '--dap[speak the Debug Adapter Protocol over stdio]'
    '--build[AOT-compile the script bytecode into the cache]'
    '--aot[AOT-compile the script to a standalone native .fvm executable]'
    '-o[output path for --aot]:output file:_files'
    '--output[output path for --aot]:output file:_files'
    '--dump-tokens[print the lexer token stream]'
    '--dump-ast[print the parsed AST]'
    '--disasm[disassemble the lowered fusevm bytecode]'
    '-h[show help]'
    '--help[show help]'
    '-V[show version]'
    '--version[show version]'
    '*:R script:_files -g "*.R"'
  )
  _arguments -s $opts
}

_Rscript "$@"
